<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".MainActivity">

    <!-- Logo e Título -->
    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/ic_fitness_logo"
        android:contentDescription="FitMeet Logo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintBottom_toTopOf="@id/tvAppTitle"
        android:layout_marginTop="60dp" />

    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FitMeet"
        android:textSize="42sp"
        android:textStyle="bold"
        android:textColor="@color/green_primary"
        android:fontFamily="@font/roboto_bold"
        app:layout_constraintTop_toBottomOf="@id/ivLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvSubtitle"
        android:layout_marginTop="12dp" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Treino Personalizado em Tempo Real"
        android:textSize="15sp"
        android:textColor="@color/text_secondary"
        app:layout_constraintTop_toBottomOf="@id/tvAppTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cardRoomSetup"
        android:layout_marginTop="6dp" />

    <!-- Card de Configuração da Sala -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardRoomSetup"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnEnterRoom"
        android:layout_marginTop="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Nome do Usuário -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Seu Nome"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilUserName"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxStrokeColor="@color/green_primary"
                app:hintTextColor="@color/green_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etUserName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ex: João Silva"
                    android:textColor="@color/text_primary"
                    android:inputType="textPersonName"
                    android:imeOptions="actionNext" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Nome da Sala -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Código da Sala de Treino"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilRoomName"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxStrokeColor="@color/green_primary"
                app:hintTextColor="@color/green_primary"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/ic_refresh"
                app:endIconContentDescription="Gerar sala aleatória">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRoomName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ex: treino-joao-segunda"
                    android:textColor="@color/text_primary"
                    android:inputType="textNoSuggestions"
                    android:imeOptions="actionDone" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Perfil: Professor ou Aluno -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Meu Perfil"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="10dp" />

            <RadioGroup
                android:id="@+id/rgProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbStudent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Aluno"
                    android:textColor="@color/text_primary"
                    android:checked="true"
                    android:buttonTint="@color/green_primary" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbTrainer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Personal Trainer"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/green_primary" />

            </RadioGroup>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Botão Entrar na Sala -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEnterRoom"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        android:text="INICIAR TREINO"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        app:backgroundTint="@color/green_primary"
        app:cornerRadius="16dp"
        app:icon="@drawable/ic_fitness_center"
        app:iconGravity="textStart"
        app:layout_constraintTop_toBottomOf="@id/cardRoomSetup"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvVersion" />

    <!-- Versão -->
    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0.0 • Powered by Jitsi Meet"
        android:textSize="11sp"
        android:textColor="@color/text_hint"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
