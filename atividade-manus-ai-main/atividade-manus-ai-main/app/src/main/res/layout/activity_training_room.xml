<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    tools:context=".TrainingRoomActivity">

    <!-- ============================================================ -->
    <!--  PARTE SUPERIOR — Vídeo Jitsi Meet (60% da tela)            -->
    <!-- ============================================================ -->
    <FrameLayout
        android:id="@+id/jitsiContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="6"
        android:background="@color/black">

        <!-- O JitsiMeetView será adicionado programaticamente aqui -->

        <!-- Barra de status da sala (sobreposta ao vídeo) -->
        <LinearLayout
            android:id="@+id/llRoomStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#AA000000"
            android:padding="8dp"
            android:gravity="center_vertical">

            <View
                android:id="@+id/viewStatusDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_status_dot"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvRoomName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Conectando..."
                android:textColor="@color/white"
                android:textSize="13sp"
                tools:text="treino-joao-segunda" />

            <TextView
                android:id="@+id/tvParticipants"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👥 1"
                android:textColor="@color/white"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Botão de encerrar chamada -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabEndCall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="12dp"
            android:src="@drawable/ic_call_end"
            android:contentDescription="Encerrar chamada"
            app:backgroundTint="@color/red_error"
            app:fabSize="mini" />

    </FrameLayout>

    <!-- Divisor visual -->
    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="@color/green_primary" />

    <!-- ============================================================ -->
    <!--  PARTE INFERIOR — Ferramentas de Treino (40% da tela)       -->
    <!-- ============================================================ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="4"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ===== CRONÔMETRO DIGITAL ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardTimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Título do cronômetro -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_timer"
                            android:contentDescription="Cronômetro"
                            app:tint="@color/green_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="  CRONÔMETRO"
                            android:textColor="@color/green_primary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />

                    </LinearLayout>

                    <!-- Display do cronômetro -->
                    <TextView
                        android:id="@+id/tvTimer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="00:00:00"
                        android:textSize="56sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.05"
                        android:layout_marginVertical="8dp" />

                    <!-- Botões do cronômetro -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <!-- Botão INICIAR -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTimerStart"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="INICIAR"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/green_primary"
                            app:cornerRadius="12dp"
                            app:icon="@drawable/ic_play"
                            app:iconGravity="textStart"
                            app:iconSize="18dp" />

                        <!-- Botão PAUSAR -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTimerPause"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="6dp"
                            android:text="PAUSAR"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:enabled="false"
                            app:backgroundTint="@color/orange_accent"
                            app:cornerRadius="12dp"
                            app:icon="@drawable/ic_pause"
                            app:iconGravity="textStart"
                            app:iconSize="18dp" />

                        <!-- Botão ZERAR -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTimerReset"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="ZERAR"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/card_bg_light"
                            app:cornerRadius="12dp"
                            app:icon="@drawable/ic_reset"
                            app:iconGravity="textStart"
                            app:iconSize="18dp" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== CONTADOR DE REPETIÇÕES ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardReps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Título do contador -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_fitness_center"
                            android:contentDescription="Repetições"
                            app:tint="@color/orange_accent" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="  REPETIÇÕES"
                            android:textColor="@color/orange_accent"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />

                        <!-- Botão de reset do contador -->
                        <ImageButton
                            android:id="@+id/btnRepsReset"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_reset"
                            android:contentDescription="Zerar repetições"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            app:tint="@color/text_secondary" />

                    </LinearLayout>

                    <!-- Nome do exercício -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilExerciseName"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxStrokeColor="@color/orange_accent"
                        app:hintTextColor="@color/orange_accent">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etExerciseName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Nome do exercício"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Display e botões do contador -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Botão DIMINUIR -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRepsMinus"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:text="−"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/card_bg_light"
                            app:cornerRadius="32dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp" />

                        <!-- Display do contador -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvRepsCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="64sp"
                                android:textStyle="bold"
                                android:textColor="@color/white"
                                android:gravity="center"
                                android:fontFamily="monospace" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="repetições"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary"
                                android:gravity="center" />

                        </LinearLayout>

                        <!-- Botão AUMENTAR -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRepsPlus"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:text="+"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/orange_accent"
                            app:cornerRadius="32dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp" />

                    </LinearLayout>

                    <!-- Séries concluídas -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Séries concluídas:"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvSetsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/orange_accent"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAddSet"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="+ Série"
                            android:textSize="12sp"
                            app:backgroundTint="@color/green_dark"
                            app:cornerRadius="8dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== NOTAS RÁPIDAS ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋  NOTAS DO TREINO"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxStrokeColor="@color/card_bg_light">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNotes"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Anotações do treino de hoje..."
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:minLines="3"
                            android:gravity="top"
                            android:inputType="textMultiLine" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
