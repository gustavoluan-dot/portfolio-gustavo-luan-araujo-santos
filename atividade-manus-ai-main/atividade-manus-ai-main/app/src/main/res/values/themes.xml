<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Tema principal do FitMeet — Dark Theme com verde fitness -->
    <style name="Theme.FitMeet" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Cores primárias -->
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryVariant">@color/green_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Cores secundárias -->
        <item name="colorSecondary">@color/orange_accent</item>
        <item name="colorSecondaryVariant">@color/orange_light</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Fundo -->
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/card_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Erro -->
        <item name="colorError">@color/red_error</item>
        <item name="colorOnError">@color/white</item>

        <!-- Status bar e navigation bar escuras -->
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Tipografia -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <!-- Tema para a tela de splash (sem action bar) -->
    <style name="Theme.FitMeet.Splash" parent="Theme.FitMeet">
        <item name="android:windowBackground">@color/bg_dark</item>
    </style>

</resources>
